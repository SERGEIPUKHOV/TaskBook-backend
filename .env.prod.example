APP_ENV=production
SECRET_KEY=replace_with_random_64_char_secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
RESET_TOKEN_EXPIRE_MINUTES=60
DATABASE_URL=postgresql+asyncpg://taskbook:taskbook@db:5432/taskbook
REDIS_URL=redis://redis:6379/0
AUTO_CREATE_TABLES=false
RATE_LIMIT_ENABLED=true
SEED_DEMO_USER=false
SEED_ADMIN_USER=false
LOG_LEVEL=INFO
DASHBOARD_CACHE_TTL=60
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=3600
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
ACCESS_COOKIE_NAME=taskbook_access
REFRESH_COOKIE_NAME=taskbook_refresh
SESSION_COOKIE_NAME=taskbook_session
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_SECURE=true
CORS_ORIGINS=https://taskbook.app,https://www.taskbook.app,https://admin.taskbook.app
POSTGRES_USER=taskbook
POSTGRES_PASSWORD=replace_with_real_postgres_password
POSTGRES_DB=taskbook
